ENV=dev
APP_NAME=Vionix IA

# Servidor — 0.0.0.0 expone Swagger en la red local (http://TU_IP:8000/docs)
API_HOST=0.0.0.0
API_PORT=8000
DOCS_ENABLED=true

# Base de datos
# Local sin Docker (recomendado para empezar):
DATABASE_URL=sqlite+aiosqlite:///./var/vionix.db
# Con Docker / producción (PostgreSQL, residencia UE):
# DATABASE_URL=postgresql+asyncpg://vionix:vionix@localhost:5432/vionix

# Almacenamiento de audio (minimización RGPD: se borra tras transcribir)
AUDIO_STORAGE_DIR=./var/audio
DELETE_AUDIO_AFTER_TRANSCRIPTION=true

# STT: mock | gladia | speechmatics
STT_PROVIDER=mock
STT_API_KEY=
STT_LANGUAGE=es
GLADIA_MODEL=solaria-3
GLADIA_POLL_INTERVAL_SEC=2.0
GLADIA_POLL_TIMEOUT_SEC=600

# LLM: mock | mistral
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=mistral-small-latest

# Cola de trabajos: asyncio (MVP) | celery (futuro)
JOB_QUEUE=asyncio

# Seguridad OIDC — el backend valida el JWT del IdP (no maneja contraseñas).
# En dev, con AUTH_DEV_BYPASS=true y sin token, se permite un usuario simulado.
# Fuera de dev (ENV=staging/production) el bypass se ignora y se exige token real.
# Con el Keycloak de docker-compose:
#   OIDC_ISSUER=http://localhost:8080/realms/vionix
#   OIDC_AUDIENCE=vionix-api
OIDC_ISSUER=
OIDC_AUDIENCE=
# Opcional: fija el JWKS; si se deja vacío se descubre desde el issuer (.well-known).
OIDC_JWKS_URL=
AUTH_DEV_BYPASS=true
